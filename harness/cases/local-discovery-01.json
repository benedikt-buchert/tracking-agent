{
  "$schema": "../schemas/signal-backed-case.schema.json",
  "case_id": "local-discovery-01",
  "site_id": "local-demo",
  "family_id": null,
  "kind": "local",
  "entry_url": "http://localhost:4321/",
  "journey_hint": "Navigate the deterministic checkout fixture. Start from the landing page, proceed through checkout (fill shipping details), then through payment (fill card details) to reach the confirmation or profile page. Observe tracking events fired into the dataLayer at each step.",
  "tags": ["local", "checkout", "datalayer", "deterministic"],
  "difficulty": "easy",
