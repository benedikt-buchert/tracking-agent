{
  "name": "tracking-agent",
  "version": "0.1.0",
  "description": "Browser-based tracking validation agent using Stagehand",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/benedikt-buchert/tracking-agent.git"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "bin": {
    "tracking-agent": "dist/run.js"
  },
  "scripts": {
    "build": "tsc",
    "prepack": "npm run build",
    "typecheck": "tsc --noEmit",
    "start": "node dist/run.js",
    "dev": "npx tsx --env-file=.env src/run.ts",
    "test": "vitest run",
    "test:integration": "node --import tsx src/integration/run-suite.ts -- vitest run -c vitest.integration.config.ts",
    "demo:serve": "node --import tsx src/integration/serve-demo.ts",
    "test:coverage": "vitest run --coverage.enabled true --coverage.provider v8 --coverage.reporter json",
    "knip": "knip",
    "quality:staged": "npm run lint && npm run test:coverage && npm run typecheck && node --import tsx src/quality/crap-report.ts --staged --threshold 30",
    "test:crap": "npm run test:coverage && node --import tsx src/quality/crap-report.ts",
    "test:watch": "vitest",
    "test:mutation": "stryker run",
    "test:mutation:file": "stryker run --mutate",
    "test:mutation:changed": "node --import tsx src/quality/mutation-run.ts --staged",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "check": "npm run lint && npm run test",
    "verify": "npm run lint && npm run test && npm run typecheck",
    "verify:local": "npm run verify && npm run test:integration",
    "verify:local:headed": "npm run verify && npm run test:integration",
    "prepare": "husky"
  },
  "devDependencies": {
    "@stryker-mutator/core": "^9.3.1",
    "@stryker-mutator/typescript-checker": "^9.3.1",
    "@stryker-mutator/vitest-runner": "^9.3.1",
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "@vitest/coverage-v8": "^4.1.0",
    "eslint": "^8.57.1",
    "eslint-plugin-vitest": "^0.5.4",
    "fast-check": "^4.3.0",
    "husky": "^9.1.7",
    "knip": "^6.1.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "@browserbasehq/stagehand": "^3.2.0",
    "ajv": "^8.18.0",
    "ajv-draft-04": "^1.0.0",
    "ajv-formats": "^3.0.1",
    "ajv-keywords": "^5.1.0",
    "chalk": "^5.6.2"
  }
}
